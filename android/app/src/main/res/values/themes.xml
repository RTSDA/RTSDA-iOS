<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.RTSDA" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/ic_launcher_background</item>
        <item name="android:statusBarColor">@color/ic_launcher_background</item>
        <item name="android:navigationBarColor">@color/ic_launcher_background</item>
    </style>

    <style name="Theme.RTSDA.Starting" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Set the splash screen background -->
        <item name="android:windowBackground">@color/ic_launcher_background</item>
        
        <!-- Configure the splash screen -->
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/ic_launcher_background</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/splash_icon</item>
        <item name="android:windowSplashScreenIconBackgroundColor" tools:targetApi="s">@android:color/transparent</item>
        <item name="android:windowSplashScreenAnimationDuration" tools:targetApi="s">1000</item>
        
        <!-- Status bar and navigation bar settings -->
        <item name="android:statusBarColor">@color/ic_launcher_background</item>
        <item name="android:navigationBarColor">@color/ic_launcher_background</item>
    </style>
</resources>